---
import { basename as posixBasename, extname as posixExtname } from 'node:path/posix';
import { basename as winBasename } from 'node:path/win32';
import BaseLayout from '../layouts/BaseLayout.astro';

type Member = {
  order: number;
  name: string;
  position: string;
  contact?: unknown;
  researchInterests?: unknown;
  website?: unknown;
  photo?: unknown;
};

type MemberWithPhotoUrl = Member & {
  contactLines: ContactPart[][];
  researchInterestsList: string[];
  websiteUrl?: string;
  photoUrl?: string;
};

type ContactPart =
  | { type: 'text'; value: string }
  | { type: 'link'; href: string; value: string };

const allowedPhotoExtensions = new Set(['.jpg', '.jpeg', '.png', '.webp', '.svg']);
const photoModules = import.meta.glob<string>('../data/members/*.{jpg,jpeg,png,webp,svg}', {
  eager: true,
  query: '?url',
  import: 'default',
});
const photoByFileName = Object.fromEntries(
  Object.entries(photoModules).map(([path, url]) => [path.split('/').pop(), url]),
) as Record<string, string>;

function getOptionalString(value: unknown) {
  if (typeof value !== 'string') {
    return undefined;
  }

  const trimmed = value.trim();
  return trimmed ? trimmed : undefined;
}

function isAllowedLinkTarget(value: string) {
  return value.startsWith('https://') || value.startsWith('http://') || value.startsWith('mailto:');
}

function parseContactLine(contact: string): ContactPart[] {
  const parts: ContactPart[] = [];
  const linkPattern = /\[([^\]]+)\]\(([^)]+)\)/g;
  let lastIndex = 0;
  let match: RegExpExecArray | null;

  while ((match = linkPattern.exec(contact))) {
    const [raw, label, href] = match;
    const cleanLabel = label.trim();
    const cleanHref = href.trim();

    if (match.index > lastIndex) {
      parts.push({ type: 'text', value: contact.slice(lastIndex, match.index) });
    }

    if (cleanLabel && isAllowedLinkTarget(cleanHref)) {
      parts.push({ type: 'link', href: cleanHref, value: cleanLabel });
    } else {
      parts.push({ type: 'text', value: raw });
    }

    lastIndex = match.index + raw.length;
  }

  if (lastIndex < contact.length) {
    parts.push({ type: 'text', value: contact.slice(lastIndex) });
  }

  return parts.length ? parts : [{ type: 'text', value: contact }];
}

function getContactLines(value: unknown): ContactPart[][] {
  if (Array.isArray(value)) {
    return value.map((line) => getOptionalString(line)).filter((line): line is string => {
      return Boolean(line);
    }).map(parseContactLine);
  }

  const contact = getOptionalString(value);
  return contact ? [parseContactLine(contact)] : [];
}

function getResearchInterests(value: unknown) {
  if (!Array.isArray(value)) {
    return [];
  }

  return value.filter((interest): interest is string => {
    return typeof interest === 'string' && interest.trim().length > 0;
  }).map((interest) => interest.trim());
}

function getMemberPhotoUrl(member: Member) {
  const photo = getOptionalString(member.photo);

  if (!photo) {
    return undefined;
  }

  const isFileNameOnly = photo === posixBasename(photo) && photo === winBasename(photo);

  if (!isFileNameOnly || photo === '.' || photo === '..') {
    console.warn(
      `Invalid member photo for ${member.name}: "${photo}" must be a file name only, e.g. taein-oh.png. Using placeholder.`,
    );
    return undefined;
  }

  const extension = posixExtname(photo).toLowerCase();

  if (!allowedPhotoExtensions.has(extension)) {
    console.warn(
      `Invalid member photo extension for ${member.name}: "${photo}". Allowed extensions: .jpg, .jpeg, .png, .webp, .svg. Using placeholder.`,
    );
    return undefined;
  }

  const photoUrl = photoByFileName[photo];

  if (!photoUrl) {
    console.warn(`Missing member photo for ${member.name}: src/data/members/${photo}. Using placeholder.`);
    return undefined;
  }

  return photoUrl;
}

const modules = import.meta.glob('../data/members/*.json', { eager: true });
const members: MemberWithPhotoUrl[] = Object.values(modules).map((module) => {
  const member = (module as { default: Member }).default;
  return {
    ...member,
    contactLines: getContactLines(member.contact),
    researchInterestsList: getResearchInterests(member.researchInterests),
    websiteUrl: getOptionalString(member.website),
    photoUrl: getMemberPhotoUrl(member),
  };
}).sort((a, b) => {
  return a.order - b.order || a.name.localeCompare(b.name);
});
---

<BaseLayout title="Members" description="Members of GRASP Lab at KAIST.">
  <section class="page-heading">
    <h1>Members</h1>
  </section>

  {
    members.length > 0 ? (
      <ul class="member-list">
        {members.map((member) => (
          <li class="member-profile">
            <div class="member-profile__photo">
              {member.photoUrl ? (
                <img src={member.photoUrl} alt={member.name} loading="lazy" />
              ) : (
                <div class="member-profile__placeholder" aria-hidden="true" />
              )}
            </div>
            <div class="member-profile__body">
              <h2>{member.name}</h2>
              <p class="member-profile__position">{member.position}</p>
              <dl class="member-profile__details">
                {member.researchInterestsList.length > 0 ? (
                  <div>
                    <dt>Research Interests</dt>
                    <dd>{member.researchInterestsList.join(', ')}</dd>
                  </div>
                ) : null}
                {member.contactLines.length > 0 ? (
                  <div>
                    <dt>Contact</dt>
                    <dd>
                      {member.contactLines.map((line) => (
                        <span class="member-profile__contact-line">
                          {line.map((part) => (
                            part.type === 'link' ? <a href={part.href}>{part.value}</a> : part.value
                          ))}
                        </span>
                      ))}
                    </dd>
                  </div>
                ) : null}
                {member.websiteUrl && (
                  <div>
                    <dt>Website</dt>
                    <dd>
                      <a class="member-profile__url" href={member.websiteUrl}>
                        {member.websiteUrl}
                      </a>
                    </dd>
                  </div>
                )}
              </dl>
            </div>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty-state">Current member information will be added here.</p>
    )
  }
</BaseLayout>
