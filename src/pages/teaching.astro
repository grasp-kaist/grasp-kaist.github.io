---
import BaseLayout from '../layouts/BaseLayout.astro';

type CourseFrontmatter = {
  title?: unknown;
  semester?: unknown;
  instructor?: unknown;
  order?: unknown;
};

type CourseModule = {
  frontmatter?: CourseFrontmatter;
};

type CourseSummary = {
  slug: string;
  title: string;
  semester?: string;
  instructor?: string;
  order?: number;
};

const courseModules = import.meta.glob('../data/teaching/*/index.md', { eager: true });

function getOptionalString(value: unknown) {
  if (typeof value !== 'string') {
    return undefined;
  }

  const trimmed = value.trim();
  return trimmed ? trimmed : undefined;
}

function getOptionalOrder(value: unknown) {
  if (typeof value === 'number' && Number.isFinite(value)) {
    return value;
  }

  if (typeof value !== 'string' || !value.trim()) {
    return undefined;
  }

  const order = Number(value);
  return Number.isFinite(order) ? order : undefined;
}

function getCourseSlug(path: string) {
  const match = path.match(/\/data\/teaching\/([^/]+)\/index\.md$/);
  return match?.[1] ?? '';
}

const courses: CourseSummary[] = Object.entries(courseModules)
  .map(([path, module]) => {
    const slug = getCourseSlug(path);
    const frontmatter = (module as CourseModule).frontmatter ?? {};

    return {
      slug,
      title: getOptionalString(frontmatter.title) ?? slug,
      semester: getOptionalString(frontmatter.semester),
      instructor: getOptionalString(frontmatter.instructor),
      order: getOptionalOrder(frontmatter.order),
    };
  })
  .filter((course) => course.slug)
  .sort((a, b) => {
    const orderDifference = (a.order ?? Number.POSITIVE_INFINITY) - (b.order ?? Number.POSITIVE_INFINITY);
    return orderDifference || a.title.localeCompare(b.title);
  });
---

<BaseLayout title="Teaching" description="Teaching information for GRASP Lab at KAIST.">
  <section class="page-heading">
    <h1>Teaching</h1>
  </section>

  {
    courses.length > 0 ? (
      <ol class="course-list">
        {courses.map((course) => (
          <li class="content-entry">
            <h2 class="entry-title">
              <a href={`/teaching/${course.slug}`}>{course.title}</a>
            </h2>
            {(course.semester || course.instructor) && (
              <p class="entry-meta">
                {course.semester && <span>{course.semester}</span>}
                {course.instructor && <span>{course.instructor}</span>}
              </p>
            )}
          </li>
        ))}
      </ol>
    ) : (
      <p class="empty-state">Teaching information will be added here.</p>
    )
  }
</BaseLayout>
