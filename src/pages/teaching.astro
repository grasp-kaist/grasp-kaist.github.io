---
import BaseLayout from '../layouts/BaseLayout.astro';

type CourseFrontmatter = {
  title?: unknown;
};

type CourseModule = {
  frontmatter?: CourseFrontmatter;
};

type CourseSummary = {
  slug: string;
  title: string;
};

const courseModules = import.meta.glob('../data/teaching/*/index.md', { eager: true });

function getOptionalString(value: unknown) {
  if (typeof value !== 'string') {
    return undefined;
  }

  const trimmed = value.trim();
  return trimmed ? trimmed : undefined;
}

function getCourseSlug(path: string) {
  const match = path.match(/\/data\/teaching\/([^/]+)\/index\.md$/);
  return match?.[1] ?? '';
}

const courses: CourseSummary[] = Object.entries(courseModules)
  .map(([path, module]) => {
    const slug = getCourseSlug(path);
    const frontmatter = (module as CourseModule).frontmatter ?? {};

    return {
      slug,
      title: getOptionalString(frontmatter.title) ?? slug,
    };
  })
  .filter((course) => course.slug)
  .sort((a, b) => a.title.localeCompare(b.title));
---

<BaseLayout title="Teaching" description="Teaching information for GRASP Lab at KAIST.">
  <section class="page-heading">
    <h1>Teaching</h1>
  </section>

  {
    courses.length > 0 ? (
      <ol class="course-list">
        {courses.map((course) => (
          <li class="content-entry">
            <h2 class="entry-title">
              <a href={`/teaching/${course.slug}`}>{course.title}</a>
            </h2>
          </li>
        ))}
      </ol>
    ) : (
      <p class="empty-state">Teaching information will be added here.</p>
    )
  }
</BaseLayout>
